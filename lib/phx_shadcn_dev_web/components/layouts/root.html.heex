<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="description" content="Phoenix LiveView component library mirroring shadcn/ui — 39 components, 22 JS hooks, 3-mode state ownership. Visually faithful, LiveView-native." />

    <%!-- Open Graph --%>
    <meta property="og:type" content="website" />
    <meta property="og:title" content="PhxShadcn — shadcn/ui for Phoenix LiveView" />
    <meta property="og:description" content="39 LiveView-native components, 22 JS hooks, 3-mode state ownership. Not a React wrapper — built from scratch for LiveView." />
    <meta property="og:url" content="https://phx-shadcn-dev.fly.dev" />
    <meta property="og:site_name" content="PhxShadcn" />

    <%!-- Twitter/Bluesky --%>
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="PhxShadcn — shadcn/ui for Phoenix LiveView" />
    <meta name="twitter:description" content="39 LiveView-native components, 22 JS hooks, 3-mode state ownership. Built from scratch for LiveView." />

    <.live_title default="PhxShadcn" suffix=" · shadcn/ui for Phoenix LiveView">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      // Apply theme config before first paint to prevent flash
      (() => {
        let mode, radius;
        try {
          const cfg = JSON.parse(localStorage.getItem("phx-shadcn-theme-config"));
          if (cfg) { mode = cfg.mode; radius = cfg.radius; }
        } catch (_) {}
        // Fall back to legacy key
        if (!mode) {
          const legacy = localStorage.getItem("phx-shadcn-theme");
          if (legacy) mode = legacy;
        }
        if (mode === "dark" || (!mode && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
        if (typeof radius === "number") {
          document.documentElement.style.setProperty("--radius", radius + "rem");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    {@inner_content}
  </body>
</html>
